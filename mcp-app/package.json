{
  "name": "@openyida/mcp-app",
  "version": "0.1.1",
  "description": "OpenYida MCP App — Interactive UIs for Yida low-code platform in Claude, ChatGPT and other MCP hosts",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "openyida-mcp": "./dist/main.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build:views": "cross-env INPUT=src/views/app-dashboard/app-dashboard.html vite build && cross-env INPUT=src/views/report-chart/report-chart.html vite build && cross-env INPUT=src/views/form-preview/form-preview.html vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:views && npm run build:server",
    "dev": "concurrently \"cross-env NODE_ENV=development npm run build:views -- --watch\" \"tsx --watch src/main.ts\"",
    "start": "node dist/main.js",
    "start:stdio": "node dist/main.js --stdio",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-app",
    "mcp-server",
    "yida",
    "openyida",
    "low-code",
    "interactive-ui",
    "dingtalk",
    "aliwork"
  ],
  "author": "OpenYida Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openyida/openyida.git",
    "directory": "mcp-app"
  },
  "bugs": {
    "url": "https://github.com/openyida/openyida/issues"
  },
  "homepage": "https://github.com/openyida/openyida/tree/main/mcp-app#readme",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "openyida": ">=2026.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
