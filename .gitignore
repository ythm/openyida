# See https://help.github.com/ignore-files/ for more about ignoring files.

# dependencies
node_modules/

# build output
dist/
*.tgz

# TypeScript build outputs
**/*.d.ts
**/*.js.map
**/*.d.ts.map

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# lock files (npm only)
pnpm-lock.yaml
yarn.lock

# editors & IDEs
.idea/
.vscode/
*.swp
*.swo
*.dia~
.happypack
.aone_copilot

# OS
.DS_Store
Thumbs.db

# environment
.env
.env.local
.env.*.local

# coverage
coverage/

# AI 工具配置（保留 CLAUDE.md）
.claude/*
!.claude/CLAUDE.md


# 根目录缓存（临时文件，不入库）
.cache/
# ── openyida 用户工作区 ────────────────────────────
# 登录态 & Schema 缓存（敏感信息，不入库）
project/.cache/*
!project/.cache/.gitkeep
!project/.cache/demo-*

# 自定义页面编译产物
project/pages/dist/*
!project/pages/dist/.gitkeep

# 用户自定义页面源码（保留 demo 示例）
project/pages/src/*
project/pages/assets/*
project/pages/tmp/*
!project/pages/src/demo-*

# 需求文档（保留 demo 示例）
project/prd/*
!project/prd/demo-*

project/tmp/
examples/

# ── 根目录临时/测试/生成文件（不入库） ────────────
_temp_*
_test_*
_test-*
temp_*
test_rjsx*
fix-all.py
fix-encoding.py
optimized_text.txt
output.txt
unique_urls.txt
urls.txt
form_page.png
nul
tmp/
DEPTH-LEARNING-APP.md
PAGE_ANALYSIS.md

# ── CLI 包装器（本地生成，不入库） ───────────────
/openyida
/openyida.cmd
/openyida.ps1
/yida
/yida.cmd
/yida.ps1